# ============================================
# ResQ AI — Environment Configuration Template
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# ── AI SERVICES ──────────────────────────────
OPENAI_API_KEY=your-openai-api-key
GEMINI_API_KEY=your-gemini-api-key
OPENAI_MODEL=gpt-4o
GEMINI_MODEL=gemini-1.5-pro

# ── DATABASE ─────────────────────────────────
DATABASE_URL=postgresql://resqai:password@localhost:5432/resqai_db
DIRECT_URL=postgresql://resqai:password@localhost:5432/resqai_db

# ── REDIS ────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=your-redis-password

# ── JWT AUTH ─────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-minimum-32-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-key-minimum-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── FIREBASE ─────────────────────────────────
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY=your-firebase-private-key
FIREBASE_CLIENT_EMAIL=your-firebase-client-email
FIREBASE_STORAGE_BUCKET=your-firebase-storage-bucket

# ── SUPABASE ─────────────────────────────────
SUPABASE_URL=https://qibwuchewgamwbrfmbis.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-key
NEXT_PUBLIC_SUPABASE_URL=https://qibwuchewgamwbrfmbis.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_eE53i_csC9eI6beFJg3-WQ_E0135GR9

# ── MAPS ─────────────────────────────────────
# Using OpenStreetMap (FREE - No API key required)
# Optional: Mapbox for advanced features
MAPBOX_TOKEN=your-mapbox-token-optional

# ── PUSH NOTIFICATIONS ───────────────────────
FCM_SERVER_KEY=your-fcm-server-key
APNS_KEY_ID=your-apns-key-id
APNS_TEAM_ID=your-apns-team-id

# ── EMAIL SERVICE ────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=noreply@resqai.pk

# ── SMS SERVICE ──────────────────────────────
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token
TWILIO_PHONE_NUMBER=+1234567890

# ── APP CONFIG ───────────────────────────────
NODE_ENV=development
PORT=3001
API_URL=http://localhost:3001
WEB_URL=http://localhost:3000
AI_SERVICE_URL=http://localhost:8000

# ── CORS ─────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ── RATE LIMITING ────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ── ENCRYPTION ───────────────────────────────
ENCRYPTION_KEY=your-32-char-encryption-key-here
ENCRYPTION_IV=your-16-char-iv-here

# ── LOGGING ──────────────────────────────────
LOG_LEVEL=info
LOG_FILE=logs/app.log

# ── DEPLOYMENT ───────────────────────────────
# Vercel (Web)
VERCEL_TOKEN=your-vercel-token

# Railway/Render (Backend)
RAILWAY_TOKEN=your-railway-token
